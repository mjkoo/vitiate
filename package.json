{
  "name": "vitiate-root",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">= 22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "cargo test --workspace && turbo run test",
    "test:cargo": "cargo test --workspace",
    "test:js": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:instrumentation": "turbo run test:instrumentation",
    "format": "cargo fmt && prettier --write .",
    "format:check": "cargo fmt --check && prettier --check .",
    "lint": "cargo clippy --workspace --all-targets -- -D warnings && pnpm exec eslint .",
    "lint:cargo": "cargo clippy --workspace --all-targets -- -D warnings",
    "lint:js": "pnpm exec eslint .",
    "check": "turbo run check",
    "publish": "turbo run publish",
    "docs:dev": "turbo run dev --filter=@vitiate/docs",
    "docs:build": "turbo run build --filter=@vitiate/docs",
    "prepare": "lefthook install"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-rf6f-7fwh-wjgh"
      ]
    },
    "overrides": {
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "smol-toml@<1.6.1": "1.6.1",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
