{
  "name": "vitiate-root",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "cargo test --workspace && turbo run test",
    "test:cargo": "cargo test --workspace",
    "test:js": "turbo run test",
    "test:e2e": "turbo run test:fuzz-pipeline",
    "format": "cargo fmt && prettier --write .",
    "format:check": "cargo fmt --check && prettier --check .",
    "lint": "cargo clippy --workspace --all-targets -- -D warnings && pnpm exec eslint .",
    "lint:cargo": "cargo clippy --workspace --all-targets -- -D warnings",
    "lint:js": "pnpm exec eslint .",
    "check": "turbo run check",
    "publish": "turbo run publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
