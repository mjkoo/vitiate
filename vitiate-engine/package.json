{
  "name": "@vitiate/engine",
  "version": "0.1.0",
  "description": "Native Node.js addon for vitiate",
  "type": "commonjs",
  "main": "index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjkoo/vitiate.git",
    "directory": "vitiate-engine"
  },
  "keywords": [
    "fuzzing",
    "libafl",
    "coverage-guided",
    "native-addon",
    "napi"
  ],
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "napi": {
    "binaryName": "vitiate-engine",
    "packageName": "@vitiate/engine",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "armv7-unknown-linux-gnueabihf",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "test": "node test/smoke.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0"
  },
  "optionalDependencies": {
    "@vitiate/engine-win32-x64-msvc": "workspace:*",
    "@vitiate/engine-win32-arm64-msvc": "workspace:*",
    "@vitiate/engine-linux-x64-gnu": "workspace:*",
    "@vitiate/engine-linux-x64-musl": "workspace:*",
    "@vitiate/engine-linux-arm64-gnu": "workspace:*",
    "@vitiate/engine-linux-arm64-musl": "workspace:*",
    "@vitiate/engine-linux-arm-gnueabihf": "workspace:*",
    "@vitiate/engine-darwin-x64": "workspace:*",
    "@vitiate/engine-darwin-arm64": "workspace:*"
  }
}
