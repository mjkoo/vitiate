{
  "name": "@vitiate/fuzzed-data-provider",
  "version": "0.1.3",
  "description": "A modern fuzzer for the JavaScript ecosystem - structured input provider for fuzz targets",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjkoo/vitiate.git",
    "directory": "vitiate-fuzzed-data-provider"
  },
  "engines": {
    "node": ">= 18"
  },
  "keywords": [
    "fuzzing",
    "fuzz-testing",
    "fuzzed-data-provider",
    "structured-fuzzing"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
