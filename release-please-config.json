{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true },
    { "type": "chore", "section": "Miscellaneous Chores", "hidden": true },
    { "type": "refactor", "section": "Code Refactoring", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Build System", "hidden": true },
    { "type": "ci", "section": "Continuous Integration", "hidden": true }
  ],
  "packages": {
    ".": {
      "release-type": "node",
      "component": "vitiate",
      "extra-files": [
        {
          "type": "json",
          "path": "vitiate-core/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/npm/darwin-arm64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/npm/linux-arm64-gnu/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/npm/linux-arm64-musl/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/npm/linux-arm-gnueabihf/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/npm/linux-x64-gnu/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/npm/linux-x64-musl/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-engine/npm/win32-x64-msvc/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-swc-plugin/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate-fuzzed-data-provider/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "vitiate/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        }
      ]
    }
  }
}
