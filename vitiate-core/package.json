{
  "name": "@vitiate/core",
  "version": "0.3.1",
  "description": "A modern fuzzer for the JavaScript ecosystem - Vitest plugin, fuzz API, CLI, and corpus management",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjkoo/vitiate.git",
    "directory": "vitiate-core"
  },
  "engines": {
    "node": ">= 18"
  },
  "keywords": [
    "fuzzing",
    "fuzz-testing",
    "coverage-guided",
    "security",
    "vitest",
    "vitest-plugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:instrumentation": "vitest run --config test/vitest.instrumented.config.ts && pnpm run test:cjs-dep && pnpm run test:cjs-fixture",
    "test:cjs-dep": "vitest run --config test/vitest.cjs-dep.config.ts",
    "test:cjs-fixture": "vitest run --config test/vitest.cjs-fixture.config.ts",
    "test:e2e": "vitest run --config test/vitest.e2e.config.ts"
  },
  "dependencies": {
    "@optique/core": "1.1.1",
    "@optique/run": "1.1.1",
    "@swc/core": "^1.15.43",
    "@vitiate/engine": "workspace:*",
    "@vitiate/swc-plugin": "workspace:*",
    "cjs-module-lexer": "^2.2.0",
    "es-module-lexer": "^2.3.1",
    "esbuild": "^0.28.1",
    "escape-string-regexp": "^5.0.0",
    "ipaddr.js": "^2.4.0",
    "magic-string": "^1.0.0",
    "valibot": "^1.4.2"
  },
  "peerDependencies": {
    "vite": ">=6.0.0",
    "vitest": ">=3.1.0"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.14",
    "jpeg-js": "^0.4.4",
    "node-forge": "^1.3.1",
    "tsdown": "^0.22.8",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
