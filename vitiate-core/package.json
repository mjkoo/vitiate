{
  "name": "@vitiate/core",
  "version": "0.1.1",
  "description": "A modern fuzzer for the JavaScript ecosystem - Vitest plugin, fuzz API, CLI, and corpus management",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjkoo/vitiate.git",
    "directory": "vitiate-core"
  },
  "engines": {
    "node": ">= 18"
  },
  "keywords": [
    "fuzzing",
    "fuzz-testing",
    "coverage-guided",
    "security",
    "vitest",
    "vitest-plugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:instrumentation": "vitest run --config test/vitest.instrumented.config.ts",
    "test:e2e": "vitest run --config test/vitest.e2e.config.ts"
  },
  "dependencies": {
    "@optique/core": "1.0.0-dev.438+923a6492",
    "@optique/run": "1.0.0-dev.438+923a6492",
    "@swc/core": "^1.15.17",
    "@vitiate/engine": "workspace:*",
    "@vitiate/swc-plugin": "workspace:*",
    "es-module-lexer": "^1.7.0",
    "escape-string-regexp": "^5.0.0",
    "ipaddr.js": "^2.3.0",
    "magic-string": "^0.30.21",
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "vite": ">=6.0.0",
    "vitest": ">=3.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.1.0"
  }
}
