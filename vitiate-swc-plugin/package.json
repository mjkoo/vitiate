{
  "name": "@vitiate/swc-plugin",
  "version": "0.1.1",
  "description": "A modern fuzzer for the JavaScript ecosystem - SWC coverage instrumentation plugin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjkoo/vitiate.git",
    "directory": "vitiate-swc-plugin"
  },
  "engines": {
    "node": ">= 18"
  },
  "keywords": [
    "swc-plugin",
    "fuzzing",
    "coverage",
    "instrumentation"
  ],
  "main": "vitiate_swc_plugin.wasm",
  "scripts": {
    "build": "cargo build-wasip1 -p vitiate-swc-plugin --release && cp ../target/wasm32-wasip1/release/vitiate_swc_plugin.wasm ."
  },
  "files": [
    "vitiate_swc_plugin.wasm"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "preferUnplugged": true
}
