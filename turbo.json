{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "*.node", "*.wasm"]
    },
    "@vitiate/engine#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/Cargo.lock",
        "$TURBO_ROOT$/Cargo.toml"
      ],
      "outputs": ["*.node", "index.js", "index.d.ts"]
    },
    "@vitiate/swc-plugin#build": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/Cargo.lock",
        "$TURBO_ROOT$/Cargo.toml"
      ],
      "outputs": ["*.wasm"]
    },
    "@vitiate/docs#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@vitiate/docs#dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "cache": false
    },
    "check": {
      "cache": false
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:instrumentation": {
      "dependsOn": ["build"],
      "cache": false
    },
    "publish": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
